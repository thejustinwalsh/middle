{
  "name": "middle",
  "version": "0.0.0",
  "private": true,
  "description": "middle-management — autonomous GitHub issue dispatch",
  "workspaces": [
    "packages/*",
    "packages/adapters/*"
  ],
  "type": "module",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt",
    "lint": "oxlint --fix --deny-warnings",
    "mm": "bun packages/cli/src/index.ts",
    "sync-skills": "bun scripts/sync-skills.ts",
    "prepare": "git config core.hooksPath scripts/hooks 2>/dev/null && echo 'middle: enabled repo git hooks (core.hooksPath=scripts/hooks)' || true"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^6.0.3"
  }
}
